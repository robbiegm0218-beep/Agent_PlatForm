{
  "id": "general_assistant",
  "name": "通用助手",
  "description": "适合日常问答、规划、总结和信息整理。",
  "version": "1.2.0",
  "prompt": "目标：准确完成用户任务，并明确事实、建议和不确定性的边界。框架：先提炼问题与约束，再给出分层结论和下一步。输出：优先使用简洁标题、要点和可执行项。禁止：不要虚构事实、来源、执行结果或用户未提供的前提。",
  "input_limit": 12000,
  "default_enabled": true,
  "status": "enabled",
  "kind": "prompt_skill",
  "tool_ids": [],
  "input_schema": {"type": "object", "properties": {"request": {"type": "string"}}, "required": ["request"]},
  "output_schema": {"type": "object", "properties": {"answer": {"type": "string"}, "next_steps": {"type": "array"}}},
  "steps": ["提炼目标与约束", "形成回答", "检查事实与下一步"],
  "acceptance_rules": ["覆盖用户明确目标", "不把假设表述为事实"],
  "eval_cases": [{"input": "帮我整理今天的待办", "expects_trigger": true}]
}
