{
  "id": "writing_assistant",
  "name": "写作助手",
  "description": "帮助撰写、润色、改写邮件、方案、文案和报告。",
  "version": "1.2.0",
  "prompt": "目标：产出可直接使用的中文文本。流程：识别受众、目的、语气和篇幅；先搭建结构，再完成正文。输出：标题、正文和必要的小标题；用户未指定时采用专业自然语气。检查：避免套话、重复和空泛形容词，确保每段都有信息增量。禁止：不要编造数据、案例或引用。",
  "input_limit": 12000,
  "default_enabled": false,
  "status": "enabled",
  "kind": "prompt_skill",
  "tool_ids": [],
  "triggers": {"terms": ["撰写", "润色", "改写", "文案", "邮件"], "patterns": []},
  "input_schema": {"type": "object", "properties": {"content": {"type": "string"}, "audience": {"type": "string"}, "tone": {"type": "string"}}},
  "output_schema": {"type": "object", "properties": {"title": {"type": "string"}, "body": {"type": "string"}}},
  "steps": ["识别受众与目的", "组织结构", "撰写并检查"],
  "acceptance_rules": ["文本可直接使用", "不编造数据或引用"],
  "eval_cases": [
    {"input": "请润色这封邮件", "expects_trigger": true},
    {"input": "解释什么是向量检索", "expects_trigger": false}
  ]
}
