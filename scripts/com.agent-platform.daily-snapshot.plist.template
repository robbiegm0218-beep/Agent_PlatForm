<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <key>Label</key><string>com.agent-platform.daily-snapshot</string>
  <key>WorkingDirectory</key><string>__MAINTENANCE_DIR__</string>
  <key>ProgramArguments</key><array><string>__MAINTENANCE_DIR__/docker-upgrade-snapshot.sh</string></array>
  <key>StartCalendarInterval</key><dict><key>Hour</key><integer>2</integer><key>Minute</key><integer>0</integer></dict>
  <key>StandardOutPath</key><string>__LOG_DIR__/daily-snapshot.log</string>
  <key>StandardErrorPath</key><string>__LOG_DIR__/daily-snapshot-error.log</string>
</dict></plist>
