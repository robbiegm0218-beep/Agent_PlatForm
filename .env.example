# Personal hosted deployment. Copy to .env and replace every CHANGE_ME value.
AGENT_PLATFORM_ENV=production
ADMIN_EMAIL=owner@example.com
ADMIN_PASSWORD=CHANGE_ME_USE_A_LONG_UNIQUE_PASSWORD
ADMIN_NAME=Owner

HOST=127.0.0.1
PORT=8765
AGENT_DATABASE_PATH=agent_platform.db
AGENT_DATA_DIR=data

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_DEEP_MODEL=deepseek-v4-pro
DEEPSEEK_SSL_VERIFY=true

SESSION_TTL_SECONDS=1209600
RATE_LIMIT_PER_MINUTE=30
MAX_REQUEST_BYTES=65536
MAX_KNOWLEDGE_UPLOAD_BYTES=8388608
MAX_TOOL_STEPS=4
MAX_CONTEXT_TOKENS=8000
PERSONAL_DAILY_RUN_LIMIT=100
PERSONAL_MONTHLY_RUN_LIMIT=1000
PERSONAL_DAILY_TOKEN_LIMIT=200000
PERSONAL_MONTHLY_TOKEN_LIMIT=2000000

# Keep V2 disabled until the instance has passed its local fixed evaluations.
AGENT_INTELLIGENCE_V2=false
AGENT_PLANNER_MODE=off
AGENT_EVIDENCE_MODE=off
AGENT_ORCHESTRATOR_MODE=off
AGENT_VERIFIER_MODE=off
